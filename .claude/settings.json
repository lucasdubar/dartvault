{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s --max-time 1 -X POST \"http://localhost:3001/hook?type=UserPromptSubmit\" -H \"Content-Type: application/json\" -d @- 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s --max-time 1 -X POST \"http://localhost:3001/hook?type=PreToolUse\" -H \"Content-Type: application/json\" -d @- 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s --max-time 1 -X POST \"http://localhost:3001/hook?type=PostToolUse\" -H \"Content-Type: application/json\" -d @- 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s --max-time 1 -X POST \"http://localhost:3001/hook?type=Stop\" -H \"Content-Type: application/json\" -d @- 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(seomator audit:*)",
      "Bash(for f:*)",
      "Bash(do)",
      "Bash(sed -i 's/\\\\[data-theme=\"\"light\"\"\\\\] \\\\.rules-full-inner{border-top-color:rgba\\(0,0,0,0\\\\.08\\);}/[data-theme=\"\"light\"\"] .rules-full-inner{border-top-color:rgba\\(0,0,0,0.08\\);}\\\\n[data-theme=\"\"colored\"\"] .rules-quick-header{border-bottom-color:rgba\\(0,170,255,0.2\\);}\\\\n[data-theme=\"\"colored\"\"] .rules-quick-catch{color:#7DD3F5;opacity:1;}\\\\n[data-theme=\"\"colored\"\"] .rules-quick-point{background:rgba\\(0,170,255,0.07\\);border-color:rgba\\(0,170,255,0.2\\);}\\\\n[data-theme=\"\"colored\"\"] .rqp-desc{color:#7DD3F5;}\\\\n[data-theme=\"\"colored\"\"] .rules-section-title{color:#7DD3F5;border-bottom-color:rgba\\(0,170,255,0.15\\);}\\\\n[data-theme=\"\"colored\"\"] .rules-expand-btn{border-color:rgba\\(0,170,255,0.25\\);color:#7DD3F5;}\\\\n[data-theme=\"\"colored\"\"] .rules-expand-btn:hover,[data-theme=\"\"colored\"\"] .rules-expand-btn:active{background:rgba\\(0,170,255,0.1\\);color:#00AAFF;border-color:rgba\\(0,170,255,0.5\\);border-style:solid;}\\\\n[data-theme=\"\"colored\"\"] .rules-full-inner{border-top-color:rgba\\(0,170,255,0.2\\);}/' \"$f\")",
      "Bash(echo \"OK: $f\")",
      "Bash(echo \"FAIL: $f\")",
      "Bash(done)",
      "Bash(sed -i 's/\\\\[data-theme=\"\"colored\"\"\\\\] \\\\.rqp-desc{color:#7DD3F5;}/[data-theme=\"\"colored\"\"] .rqp-desc{color:rgba\\(255,255,255,0.85\\);}/' \"$f\")",
      "Bash(sed -i 's/\\\\[data-theme=\"\"colored\"\"\\\\] \\\\.rules-quick-catch{color:#7DD3F5;opacity:1;}/[data-theme=\"\"colored\"\"] .rules-quick-catch{color:rgba\\(255,255,255,0.8\\);opacity:1;}/' \"$f\")",
      "Bash(sed -i 's/\\\\[data-theme=\"\"colored\"\"\\\\] \\\\.rules-section-title{color:#7DD3F5;border-bottom-color:rgba\\(0,170,255,0\\\\.15\\);}/[data-theme=\"\"colored\"\"] .rules-section-title{color:rgba\\(255,255,255,0.5\\);border-bottom-color:rgba\\(255,255,255,0.1\\);}/' \"$f\")",
      "Bash(sed -i 's/\\\\[data-theme=\"\"colored\"\"\\\\] \\\\.rules-expand-btn{border-color:rgba\\(0,170,255,0\\\\.25\\);color:#7DD3F5;}/[data-theme=\"\"colored\"\"] .rules-expand-btn{border-color:rgba\\(255,255,255,0.2\\);color:rgba\\(255,255,255,0.6\\);}/' \"$f\")",
      "Bash(sed -i 's/\\\\[data-theme=\"\"colored\"\"\\\\] \\\\.rules-expand-btn:hover,\\\\[data-theme=\"\"colored\"\"\\\\] \\\\.rules-expand-btn:active{background:rgba\\(0,170,255,0\\\\.1\\);color:#00AAFF;border-color:rgba\\(0,170,255,0\\\\.5\\);border-style:solid;}/[data-theme=\"\"colored\"\"] .rules-expand-btn:hover,[data-theme=\"\"colored\"\"] .rules-expand-btn:active{background:rgba\\(255,255,255,0.08\\);color:#fff;border-color:rgba\\(255,255,255,0.4\\);border-style:solid;}/' \"$f\")"
    ]
  }
}
